# Plantilla de variables de entorno para docker-compose.
# Copiar a .env en la VM y completar con valores reales. NO commitear el .env real.

# --- Postgres (contenedor db) ---
POSTGRES_USER=irrigation
POSTGRES_PASSWORD=cambiar_password_seguro
POSTGRES_DB=irrigation_db

# --- Backend ---
SECRET_KEY=cambiar_secret_jwt
ENVIRONMENT=production
# URL publica del frontend (para CORS). Ajustar al subdominio o URL de Tailscale.
FRONTEND_URL=https://riego.cloud.um.edu.ar

# DATABASE_URL la define docker-compose apuntando al contenedor db; no hace falta setearla aca.

# --- Google Earth Engine (cuenta de servicio) ---
GEE_SERVICE_ACCOUNT=tu-cuenta@tu-proyecto.iam.gserviceaccount.com
GEE_CREDENTIALS_JSON={"type":"service_account",...}   # JSON completo en UNA sola linea
GEE_PROJECT_ID=irrigation-advisor-493714

# --- Web Push (VAPID) ---
VAPID_PRIVATE_KEY=cambiar_clave_privada_vapid
VAPID_PUBLIC_KEY=cambiar_clave_publica_vapid
VAPID_SUBJECT=mailto:tu@email.com

# --- Frontend build (Vite, build-time) ---
VITE_VAPID_PUBLIC_KEY=mismo_valor_que_VAPID_PUBLIC_KEY
