etadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;0d467b62-ce29-4d51-86dd-e4b743ab7efa&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;19c33455-42d5-48c0-aee5-8962686b299b&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-15T13:10:26Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;13ae6945-8093-428d-9bc5-52400f196333&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-15T13:10:26Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;6941d7bd-b8c1-40c9-8ff9-7970030803bc&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;f9396067-68b5-484c-9b48-d36f522a9681&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-04-15T13:08:20Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;2db6cf3e-2a99-4fc5-b8fe-6da38a79bd15&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;حافظت أسعار الذرة على استقرارها إلى حدّ كبير على المستوى العالمي خلال مارس/آذار وسط وفرة الإمدادات رغم تفاوت الاتجاهات الإقليمية. لكن بالمقابل، اتجهت أسعار القمح نحو الزيادة لدى البلدان المصدّرة على خلفية المخاوف المرتبطة بالطقس وارتفاع أسعار الطاقة وكذلك حالة الضبابية التي اكتنفت الزراعات مع ارتفاع تكاليف المستلزمات. وعلى التوازي مع ذلك، تراجعت أسعار الأرز على المستوى الدولي مدفوعة بتوليفة من ضغط الحصاد وانكماش الطلب على الاستيراد وتقلبات سعر صرف العملات.  وفي الأسواق المحلية الخاضعة لمراقبة منظمة الأغذية والزراعة، كانت العوامل الموسمية السبب الرئيس وراء التقلبات الشهرية في أسعار الأغذية على مدى شهري فبراير/شباط ومارس/آذار 2026. إذ استقرت أسعار الأرز تارة وتراجعت تارة أخرى عمومًا في حين ارتفعت أسعار القمح على خلفية التطورات التي تشهدها الأسواق الدولية. أما أسعار الحبوب الخشنة فكان نصيبها هو الأكبر من التقلبات متأثرة بالظروف المحلية للعرض والطلب. وفي العديد من بلدان شرق أفريقيا والشرق الأدنى، ما فتئت النزاعات وأحوال الطقس المناوئة والتحديات التي تعصف بالاقتصاد الشامل تدعم ارتفاع أسعار الأغذية الأساسية.  ويترافق التصعيد الذي تشهده النزاعات في منطقة الشرق الأدنى مع مخاطر ارتفاع أسعار الأغذية الأساسية في الأسواق المحلية، حيث شرعت عديد من البلدان استجابة لذلك بتنفيذ تدابير معينة للتخفيف من صدمات الأسعار المرتقبة والتي من المتوقع أن تأتي على خلفية ارتفاع تكاليف الطاقة واضطراب سلاسل الامداد والضغوطات التي تواجه الاقتصاد الشامل.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;06e337ff-9e47-43c1-9512-2f8f1f8999bc&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;4&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;5c43660a-07a1-4b2c-8d8d-c63e31699404&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-2029&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;174bf3f1-4138-46ec-aacd-0dfa224dfe8e&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-2010&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;f13f03d4-1a23-48b2-b5f1-0e7b708708d9&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd9328ar&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;a9def291-72e9-48a0-a8f2-eb553b5f2b1d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Arabic&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;af788bd8-3f6f-469a-b62c-4d35db0d9b23&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;منظمة الأغذية والزراعة ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;e248c8bc-c940-44d5-bf76-374594c19c98&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;نشرة خاصة FPMA&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;e87c7e23-18cc-49d2-9739-ca9bb158bf84&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;03/2026