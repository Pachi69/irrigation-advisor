  <div _ngcontent-sc860="" class="recently-added py-5">
    <div _ngcontent-sc860="" class="container">
      <hr _ngcontent-sc860="">
      <h2 _ngcontent-sc860="" class="pb-2">Recently added <ds-rss _ngcontent-sc860="" _nghost-sc175="">
  <div _ngcontent-sc175="" class="d-inline-block float-right margin-right ng-star-inserted">
    <a _ngcontent-sc175="" target="_blank" class="btn btn-secondary" href="https://openknowledge.fao.org/server/opensearch/search?format=atom&amp;query=*"><i _ngcontent-sc175="" class="fas fa-rss-square"></i></a>
  </div><!---->
