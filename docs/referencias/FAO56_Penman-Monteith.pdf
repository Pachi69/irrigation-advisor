ore/items/687d606d-5782-48c4-8ee3-90888738b917/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/687d606d-5782-48c4-8ee3-90888738b917&q;}},&q;_name&q;:&q;2024年世界渔业和水产养殖状况&q;,&q;id&q;:&q;687d606d-5782-48c4-8ee3-90888738b917&q;,&q;uuid&q;:&q;687d606d-5782-48c4-8ee3-90888738b917&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;f7719850-c4f7-43ab-9c90-c6195e936ec9&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;00d0984d-272d-49d2-8e04-c91d2e974b8d&q;,&q;language&q;:null,&q;value&q;:&q;2026-03-06T14:46:03Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;c3579aab-060f-47a2-aeec-0070282a74bc&q;,&q;language&q;:null,&q;value&q;:&q;2026-03-06T14:46:03Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;fd488ee4-7b42-4105-9293-d9f4aac840c3&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2024&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;a4842862-a90a-49cc-9047-89056b77dfe1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-03-06T14:43:37Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;d9bef234-36f3-4309-acc1-18cceca4dc40&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2024年版《世界渔业和水产养殖状况》重点介绍了“蓝色转型在行动”的内容，包括粮农组织与各成员、合作伙伴和关键利益相关方在以下方面合作开展的活动和举措：将水产食品纳入全球粮食安全和可持续性议题，加强政策咨询、科学研究和能力建设，推广可持续的做法和技术创新，并支持社区参与。本报告第1部分得益于数据收集、分析和评估工具及方法方面的重大进展，展现了世界渔业和水产养殖业的生产和利用方面的最新情况。第2部分重点介绍了粮农组织及其合作伙伴在推动转型变革以支持水产养殖规模化和集约化发展、全球渔业有效管理和水产价值链升级方面的作用。第3部分介绍了整鱼和副产品利用方面尚未发掘的潜力所带来的重大挑战和机遇，说明水产食品体系能够发挥重要作用，提在应对气候变化、保护生物多样性和环境方面提供关键且妥善的解决方案，突显出将水产食品体系纳入国家进程和多边进程的重要性。本报告还在各项预测的基础上，提出了直到2032年的未来趋势展望。本报告为政策制定者、管理者、科学家、渔民、养殖户、贸易商、民间社会活动家和消费者等广大读者们提供了有关影响渔业和水产养殖业当前及未来的挑战、机遇和创新的基于实证的最新信息，支持政策、科学和技术方面的见解。&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;3e88fbc9-356c-4c83-a706-43126e61c84a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;264 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;f66f7257-4e5a-47d9-af87-0671aad31a12&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138806-8&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1},{&q;uuid&q;:&q;060e67e0-c28f-45e5-9edc-a5d771a1df03&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138807-5&q;,&q;place&q;:1,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;e3dd1e1d-3815-4cbc-8f66-fc3da07bb009&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2663-8622&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;674cae07-2a30-4969-9a5a-fad76b85a831&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138805-1&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;ce12ad26-2516-4191-8750-66b65938f088&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;1020-5527&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;1c4976b2-3acd-4936-ac96-a2e929d8d768&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd0683zh&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;a7e9e76f-719c-4b89-a042-987318939219&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Chinese&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;4da61345-203e-49a3-90cb-358c668db448&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;粮农组织 ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;8a801acc-c5dd-4148-a94c-b7e9600fcf24&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;渔业及水产养殖通报&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;beb6a0bc-4d3f