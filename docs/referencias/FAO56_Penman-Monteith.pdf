id&q;:&q;0acc2b23-00bc-433b-a861-2eca6b628b8c&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-16T09:45:21Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;9fb2a562-86b9-4f1e-a4eb-6867f26146b8&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-16T09:45:21Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;fea66c0f-eceb-4d80-9a9a-df10b7a41826&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;744ce9bb-f5fd-4ca3-89db-c6803c8503e8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-04-16T09:44:26Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;1d5318fa-532c-4283-9d71-35246aef58eb&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Les cours mondiaux du maïs sont restés globalement stables en mars, dans un contexte d’abondance des disponibilités, malgré des tendances régionales contrastées. En revanche, les prix du blé ont augmenté dans les pays exportateurs, soutenus par des préoccupations liées aux conditions météorologiques, la hausse des prix de l’énergie et des incertitudes concernant les semis sur fond de renchérissement des coûts des intrants. Parallèlement, les prix internationaux du riz ont reculé, sous l’effet conjugué de la pression des récoltes, d’un affaiblissement de la demande d’importation et de fluctuations des taux de change. Sur les marchés intérieurs qui font l’objet d’un suivi par la FAO, les facteurs saisonniers expliquent l’essentiel des variations mensuelles des prix des denrées alimentaires de base en février et mars 2026. Les prix du riz sont demeurés globalement stables ou orientés à la baisse, tandis que ceux du blé ont progressé, reflétant l’évolution des marchés internationaux. Les prix des céréales secondaires ont affiché une volatilité plus marquée, sous l’effet de déséquilibres localisés entre l’offre et la demande. Dans plusieurs pays d’Afrique de l’Est et du Proche-Orient, les conflits, les aléas météorologiques et les difficultés macroéconomiques ont continué de maintenir les prix des denrées de base à des niveaux élevés. L’escalade du conflit au Proche-Orient fait peser des risques haussiers sur les marchés intérieurs des produits alimentaires de base. En réaction, plusieurs pays ont commencé à mettre en œuvre des mesures ciblées visant à atténuer le choc attendu sur les prix, qui devrait se transmettre principalement par le biais de la hausse des coûts de l’énergie, des perturbations des chaînes d’approvisionnement et des tensions macroéconomiques.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;f82cf1ce-426b-44bf-8110-d2b671481903&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;5&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;e0693d41-4436-4bd2-8d91-fa01043fd0fa&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-1987&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;e34475c6-9fc6-4c43-a922-12fc9214c387&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-1979&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;782c32d6-6a10-43df-a005-0c95b23cbb63&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd9328fr&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;1f9cb965-b30d-4d81-a0ab-af307d40da0d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;French&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;5532513a-7330-47cb-a28e-8386846813ca&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;a51f04c9-359a-4f19-bd6a-955739128c40&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FPMA 