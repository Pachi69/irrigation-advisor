a566b9c80/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/0da2884a-8923-440f-a780-040a566b9c80&q;}},&q;_name&q;:&q;2020年全球森林资源评估&q;,&q;id&q;:&q;0da2884a-8923-440f-a780-040a566b9c80&q;,&q;uuid&q;:&q;0da2884a-8923-440f-a780-040a566b9c80&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;202db58c-033e-4ddf-bedb-c795c214315a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;bc9ec54b-1c3a-4245-9dc8-288d82bccf2c&q;,&q;language&q;:null,&q;value&q;:&q;2025-03-26T12:12:03Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;5b1c5dd8-5752-452a-b030-351b14f54cc7&q;,&q;language&q;:null,&q;value&q;:&q;2025-03-26T12:12:03Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;8e23e26e-27ad-4713-8d2d-8bd464f0d663&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2021&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;cb77bb4c-ba62-4d80-81c7-0a36876eddb7&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-03-26T12:10:21Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;9a0bcdca-f6c6-4230-bc98-2a3710d5889f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;粮农组织于1948年完成了对世界森林资源的首次评估。当时，其主要目标是收集有关可用木材供应的信息，以满足战后重建的需求。从那时起，全球森林资源评估（FRA）已演变成对森林资源及其状况，管理和使用的全面评估，涵盖了可持续森林管理的所有主题要素。这是这些评估中的最新评估，它借鉴了全球数百名专家的努力，研究了1990-2020年期间森林资源的状况和趋势。FRA2020的制作还涉及许多合作伙伴组织之间的合作，从而减轻了国家的报告负担，增强了报告流程之间的协同作用，并改善了数据一致性。2020年森林资源评估的结果有多种格式，包括本报告和在线数据库，其中包含国家和地区的原始投入以及案头研究以及粮农组织编写的区域和全球分析。&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;4909b3f4-9c64-4722-be55-79a4b04eb843&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;184 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;3c6c5127-feff-41c6-b20d-03549778a9fa&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-134155-1&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;d00d5abf-8fd1-43d0-9dad-9b5f8eab01df&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/ca9825zh&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;fb623542-9ceb-4073-942e-9170eea17b44&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;http://www.fao.org/3/ca9825zh/ca9825zh.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;d1581ac6-751f-49d8-bc7a-4ac060c30c25&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Chinese&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;cc073315-27b5-4bf9-9483-564423040a93&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;粮农组织 ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;64837b97-6f3f-4f23-baa1-5f74797fa148&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;a1fe1995-ac28-4bad-9c9c-e5ca31472480&q;,&q;language&q;:null,&q;value&q;:&q;CC BY NC SA 3.0 IGO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;6bc7535c-6502-46a7-9dd0-c349d2ac63b0&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2020年全球森林资源评估&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.englishtranslation&q;:[{&q;uuid&q;:&q;2164c8db-ae74-4993-8e65-cad468e154a6&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Global Forest Resources Assessment 2020&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitle&q;:[{&q;uuid&q;:&q;5dd0e1dc-f701-46ac-bbdc-09c36ed86d2f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;主报告&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitleenglishtranslation&q;:[{&