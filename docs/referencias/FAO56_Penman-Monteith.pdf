-14cd79b290e0/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/c8e59cc8-7ea8-4706-bfd9-14cd79b290e0&q;}},&q;_name&q;:&q;L’État de la sécurité alimentaire et de la nutrition dans le monde 2025&q;,&q;id&q;:&q;c8e59cc8-7ea8-4706-bfd9-14cd79b290e0&q;,&q;uuid&q;:&q;c8e59cc8-7ea8-4706-bfd9-14cd79b290e0&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;53de42d2-42dd-42fb-a5fa-70fdd33789f4&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO; FIDA; OMS; PAM; UNICEF;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;fa6d1fdc-856c-4a05-a436-3554417bd4e2&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-25T11:47:13Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;809d4b9a-a84c-440d-b404-2bffda9fa835&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-25T11:47:13Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;71abcbfb-ef99-4232-929d-75dd5b193a95&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;c0148b82-c9ce-4d9d-b3bc-f37ae1437646&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-11-25T11:42:44Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;9904a7a0-6839-4b32-98b0-8dfad0e3bcdb&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Des progrès et des signes de reprise ont été observés ces dernières années, mais les niveaux restent supérieurs à ceux enregistrés avant la pandémie de covid-19, et le monde est loin d’avoir atteint l’objectif d’élimination de la faim et de l’insécurité alimentaire d’ici à 2030 (cible 2.1 des ODD). De la même façon, malgré certains progrès accomplis au regard des cibles mondiales relatives à la nutrition, le monde n’est pas dans les temps pour atteindre la cible 2.2 des ODD. Parmi d’autres facteurs, l’inflation persistante des prix des denrées alimentaires a freiné cette dynamique.L’État de la sécurité alimentaire et de la nutrition dans le monde 2025 montre comment la forte inflation a ébranlé le pouvoir d’achat dans de nombreux pays et, notamment au sein des populations à faible revenu, l’accès à une alimentation saine. Le rapport montre que l’inflation élevée des prix des denrées alimentaires est associée à une augmentation de l’insécurité alimentaire et de la malnutrition infantile. Les groupes vulnérables, notamment les ménages à faible revenu, les femmes et les communautés rurales, sont susceptibles d’être particulièrement touchés par l’inflation des prix des produits alimentaires, d’où le risque d’essuyer des revers dans la lutte contre la faim et la malnutrition.Le rapport examine les mesures prises par les pays pour faire face à ces difficultés et prévenir de futurs chocs des prix, et indique la voie à suivre dans les temps à venir. Il souligne combien une mise en œuvre cohérente des politiques budgétaires et monétaires est importante pour stabiliser les marchés, promouvoir un commerce ouvert et résilient, et protéger les populations vulnérables. Il appelle en outre à améliorer les systèmes de données et à soutenir l’investissement dans des systèmes agroalimentaires résilients pour renforcer durablement la sécurité alimentaire et la nutrition. Ces actions coordonnées sont vitales pour relancer une dynamique de progrès qui permettra d’éliminer la faim et la malnutrition d’ici à 2030.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;6c15535a-de55-4e05-82bb-b10416398e83&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;256 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;028360d5-f00f-4fab-906a-fab92ebf266b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140194-1&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;a3b8177d-9ae7-47af-ae01-110a47f1377d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2663-8630&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;6110e0e3-7941-4a89-a6b3-4208d1775bf5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140127-9&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;0a2a1ecd-a142-4b1d-8927-2853e68f33ec&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2522-7416&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;a408802d-3e65-498f-996a-4daa532c7d2f&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd6008fr&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;79ed2f26-a837-43db-b1cf-ab95e9c7481a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;French&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;16166346-9191-4d93-a1bb-b3fbb3066db2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ; FIDA ; OMS ; PAM ; UNICEF ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;ec786580-1357-459e-beba-c33c04eb0124&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;L&s;état de la securité alimentaire et de la nutrition dans le monde&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;d6ed6588-228e-4c6e-92c9-83f416812db7&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;3b3d625f-3982-4628-9777-b7e3e1516466&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;e0b7d889-f630-4541-9399-b2238e717d96&q;,&q;language&q;:null,&q;value&q;:&q;CC BY 4.0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uui