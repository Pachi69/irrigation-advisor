1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;e4a210ff-c2cd-41f6-8961-eb840344fbcc&q;,&q;language&q;:null,&q;value&q;:&q;2021-05-12T14:51:12.0000000Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;225d1e4a-8174-4b3a-8f3a-c35dfc99279f&q;,&q;language&q;:null,&q;value&q;:&q;FAO completed its first assessment of the world’s forest resources in 1948. At that time, its major objective was to collect information on available timber supply to satisfy post-war reconstruction demand. Since then, the Global Forest Resources Assessment (FRA) has evolved into a comprehensive evaluation of forest resources and their condition, management and uses, covering all the thematic elements of sustainable forest management. \nThis, the latest of these assessments, examines the status of, and trends in, forest resources over the period 1990–2020, drawing on the efforts of hundreds of experts worldwide. The production of FRA 2020 also involved collaboration among many partner organizations, thereby reducing the reporting burden on countries, increasing synergies among reporting processes, and improving data consistency. \nThe results of FRA 2020 are available in several formats, including this report and an online database containing the original inputs of countries and territories as well as desk studies and regional and global analyses prepared by FAO. I invite you to use these materials to support our common journey towards a more sustainable future with forests.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;23fe0e33-7832-408d-a20e-e1c630df82b4&q;,&q;language&q;:null,&q;value&q;:&q;184 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;6308fa43-7600-4aa9-a488-572ba3aa1250&q;,&q;language&q;:null,&q;value&q;:&q;978-92-5-132974-0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uui