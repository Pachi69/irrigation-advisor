829b7d920/mappedCollections&q;},&q;owningCollection&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/5f0cec17-98b7-4d74-9cb1-6ea829b7d920/owningCollection&q;},&q;relationships&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/5f0cec17-98b7-4d74-9cb1-6ea829b7d920/relationships&q;},&q;version&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/5f0cec17-98b7-4d74-9cb1-6ea829b7d920/version&q;},&q;templateItemOf&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/5f0cec17-98b7-4d74-9cb1-6ea829b7d920/templateItemOf&q;},&q;thumbnail&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/5f0cec17-98b7-4d74-9cb1-6ea829b7d920/thumbnail&q;},&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/5f0cec17-98b7-4d74-9cb1-6ea829b7d920/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/5f0cec17-98b7-4d74-9cb1-6ea829b7d920&q;}},&q;_name&q;:&q;The Status of Youth in Agrifood Systems&q;,&q;id&q;:&q;5f0cec17-98b7-4d74-9cb1-6ea829b7d920&q;,&q;uuid&q;:&q;5f0cec17-98b7-4d74-9cb1-6ea829b7d920&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;c9367fdc-7a65-41b1-8943-a25ade57f9c5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;fa9e9823-0cc4-4756-9ac6-8b4c0711f676&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-25T15:22:33Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;7b9d35b0-db1e-43cf-8dda-9b390eef977c&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-25T15:22:33Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;b1b4d162-7afa-4507-b5af-21211fd7e7f2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;aebd1073-f276-4542-ae5a-bef9b0293126&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-11-25T15:20:54Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;5c751ddf-bef7-4ea6-ba2a-87d0c471bb95&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;The world&s;s agrifood systems stand at a crossroads. With 1.3 billion youth globally, the future of food, livelihoods, and economic resilience depends on their participation in agrifood systems. At the same time, agrifood systems need youth to drive productivity, innovation, and sustainability in a crucial and rapidly evolving sector.FAO&s;s \&q;The Status of Youth in Agrifood Systems\&q; report is a call to action. It presents the most comprehensive, evidence-based analysis of youth in agrifood systems to date, highlighting both the opportunities and structural barriers that shape their engagement. It explores how transforming agrifood systems can enhance decent job opportunities and food security for youth, and how empowered youth can drive this transformation.It concludes highlighting policy recommendations and areas of investments to foster more equitable and sustainable agrifood systems, where rural youth are both beneficiaries and leaders of change.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;93abfa75-2b63-450a-935f-021b3d6007e7&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;350 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;8f6dc531-8bc3-47b5-9591-299abcc79135&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-139920-0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;e724095f-5d42-4137-b4e7-1434ed194a2a&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd5886en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;ea65d921-8ad4-495