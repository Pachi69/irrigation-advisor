mplateItemOf&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/eaf71fe4-8559-428d-8809-ac8212989376/templateItemOf&q;},&q;thumbnail&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/eaf71fe4-8559-428d-8809-ac8212989376/thumbnail&q;},&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/eaf71fe4-8559-428d-8809-ac8212989376/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/eaf71fe4-8559-428d-8809-ac8212989376&q;}},&q;_name&q;:&q;Food Outlook – Biannual report on global food markets&q;,&q;id&q;:&q;eaf71fe4-8559-428d-8809-ac8212989376&q;,&q;uuid&q;:&q;eaf71fe4-8559-428d-8809-ac8212989376&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;8599915b-8cee-4803-82cd-654e89273fc1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;49557d55-deb8-4952-9cfc-d46979ff06f0&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-20T18:17:35Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;b9c0cb93-b331-4a28-9895-781c39febc49&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-20T18:17:35Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;c44f3618-19e0-4bbd-8dfa-344207598cf3&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;38b1da47-c7a7-4b26-b468-12776f3d0f94&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-11-20T09:43:46Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;9a844260-806d-4d58-bfdc-70998a9551f9&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Agricultural markets remain highly sensitive to a variety of external shocks, including weather fluctuations and policy developments, and merit regular monitoring. According to the latest FAO assessments, global food commodity production has broadly increased, supported by strong consumption growth and a recovery in inventories. However, the trade outlook continues to be clouded by an evolving global trade environment and persistent policy uncertainties. Beyond the core market assessments for major food commodities, each edition includes special feature articles and key market indicators. The November 2025 edition provides an update on the fertilizer market and recent developments in olive oil markets. The overview of market indicators summarizes trends in futures markets, ocean freight rates, the global food import bill, and food price indices.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;43f0d42c-fe2a-4cfe-a45b-ab9cf82ef781&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;88 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;b9c31b64-1f51-43bb-bc0c-fe4df9b23705&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;1560-8182&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;53601f0f-64dc-4585-8764-0b97a648f0d4&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140262-7&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;14984642-8043-4e37-9def-74229056d81b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;0251-1959&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;b3774e15-0797-4fc3-8346-e8d05693d58b&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd7448en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;43bb85e9-8264-4950-9a60-5a96da49601e&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;615d5bcd-1d43-4b1