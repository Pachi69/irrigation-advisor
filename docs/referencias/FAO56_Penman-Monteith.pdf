;fao.placeofpublication&q;:[{&q;uuid&q;:&q;42e1bebc-b148-49fd-9b20-d60ada1e351b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Rome, Italy ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.previewpage&q;:[{&q;uuid&q;:&q;605f6cc2-0d1d-489d-93ac-b40d4dff3abc&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;&l;p&g;&l;b&g;Markets at a Glance&l;/b&g;&l;/p&g;&l;ul&g;&l;li&g;&l;b&g;&l;i&g;Cereals&l;/i&g;&l;/b&g;&l;/li&g; This report provides an analysis of the most recent developments in the global cereals market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_cereals.pdf\&q; target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Wheat&l;/i&g;&l;/b&g;&l;/li&g; This report provides an analysis of the most recent developments in the global wheat market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_wheat.pdf\&q; target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Coarse Grains&l;/i&g;&l;/b&g;&l;/li&g;This report provides an analysis of the most recent developments in the global coarse grains market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_grains.pdf\&q;target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Rice&l;/i&g;&l;/b&g;&l;/li&g; This report provides an analysis of the most recent developments in the global rice market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_rice.pdf\&q;target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Oilcrops, oils and meals&l;/i&g;&l;/b&g;&l;/li&g;This report provides an analysis of the most recent developments in the global oilcrops market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_oilcrops.pdf\&q;target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Sugar&l;/i&g;&l;/b&g;&l;/li&g;This report provides an analysis of the most recent developments in the global sugar market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_sugar.pdf\&q;target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Meat and meat products&l;/i&g;&l;/b&g;&l;/li&g;This report provides an analysis of the most recent developments in the global meat market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_meat.pdf\&q;target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Milk and milk products&l;/i&g;&l;/b&g;&l;/li&g;This report provides an analysis of the most recent developments in the global milk market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_milk.pdf\&q;target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;/a&g;&l;/b&g;&l;li&g;&l;b&g;&l;i&g;Fish and other acquatic products&a;nbsp;&l;/i&g;&l;/b&g;&l;/li&g;This report provides an analysis of the most recent developments in the global fish market, including a short-term outlook.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_fish.pdf\&q; target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g; Read it here&l;br&g;&l;/a&g;&l;/b&g;&l;/ul&g;&l;p&g;&l;/p&g;&l;p&g;&l;b&g;Special feature&l;/b&g;&l;/p&g;&l;p&g;&l;i&g;Fertilizer market developments&l;/i&g;&l;/p&g;&l;p&g;Fertilizer production rebounded in 2024 and 2025, led by nitrogen and potassium, while prices rose on high energy costs but remain below 2022 peaks. Global trade has stabilized, and short-term supply looks adequate, though policy risks and affordability will shape future trends.&l;b&g;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_special_feature1.pdf\&q;target=\&q;_blank\&q; class=\&q;external-link-new-window\&q; title=\&q;Opens external link in new window\&q; external=\&q;1\&q;&g;Read it here&l;/a&g;&l;/b&g;&l;/p&g;&l;p&g;&l;i&g;&l;br&g;Focus on olive oil&l;/i&g;&l;/p&g;&l;p&g;International olive oil prices declined significantly from their early 2024 peak following strong supply recovery in the 2024/25 season. As for 2025/26, tentative forecasts point to year-on-year stable olive oil production, while global consumption and trade are expected to keep expanding. Nevertheless, the sector still faces numerous challenges.&a;nbsp;&l;a href=\&q;https://www.fao.org/3/cd7448en/cd7448en_special_feature2.pdf\&q;&g;Read it here&l;/a&g;&l;/p&g;&l;p&g;&l;i&g;&l;br&g;&l;/i&g;&l;/p&g;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.specialapprover.identifier&q;:[{&q;uuid&q;:&q;f821cf0f-8132-4756-b942-df499cff0606&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;17&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.subject.agrovoc&q;:[{&q;uuid&q;:&q;6befa661-bfba-45dc-a10c-5485e541d984&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;commodity markets&q;,&q;place&q;:0,&q;authority&q;:&q;8718bc88da6d00da6e92a1e8a45adf3b27ceb552&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;14318afd-2520-4de3-a9b1-930d802789b0&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;crop production&q;,&q;place&q;:1,&q;authority&q;:&q;f6b6cf227ca7413f28d8c5ec5c9e07d805acabc9&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;65372345-5c8c-485d-8596-4156cbe425d9&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;crop forecasting&q;,&q;place&q;:2,&q;authority&q;:&q;7089b9496923574a7330690fbc4431abd9e887b7&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;8610493f-a0f9-4281-a187-f3ba798b6498&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;trade policies&q;,&q;place&q;:3,&q;authority&q;:&q;5d26b70276bf0777b63e1ddd20cbcfcb0c6b6495&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;39abdbf9-2089-48c6-baf5-88e748ed6198&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;agricultural prices&q;,&q;place&q;:4,&q;authority&q;:&q;d383062d6b3d8f1b8aec64c200188f1bf5e3adaa&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;288a03fb-a7cc-466f-b113-00959cd1fdef&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;food prices&q;,&q;place&q;:5,&q;authority&q;:&q;b9c8360cf14dd03a9ff82dc84fd639699567a93d&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;8072a032-f9f0-42a7-963b-05d1ffb1d7b1&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;international trade policies&q;,&q;place&q;:6,&q;authority&q;:&q;26a97fe36ef3b40e208c7e7d07da0e4b6a5ee9f4&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;c9d2faaa-7afd-492a-82ae-90f50d0f50eb&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;price volatility&q;,&q;place&q;:7,&q;authority&q;:&q;dc40132a99a92ac4345aff967ad08005309ca8f5&q;,&q;confidence&q;:600},{&q;uuid&q;:&q;cc33c3d3-a039-4c3e-9796-38013a64e253&q;,&q;language&q;:&q;en&q;,&q;value&q;:&q;reports&q;,&q;place&q;:8,&q;authority&q;:&q;d87b472e4e7cf9460edb83840c5658bf042057ec&q;,&q;confidence&q;:600}],&q;fao.taxonomy.category&q;:[{&q;uuid&q;:&q;69127e90-f20f-4b7f-ad22-826b31741cdc&q;,&q;language&q;:null,&q;value&q;:&q;Technical study&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.taxonomy.tier&q;:[{&q;uuid&q;:&q;c524d7cd-9ec8-4dcf-a679-227d9ee296ef&q;,&q;language&q;:null,&q;value&q;:&q;Specialized publications&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao