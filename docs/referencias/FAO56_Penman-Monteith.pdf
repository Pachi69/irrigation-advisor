q;https://openknowledge.fao.org/server/api/core/items/8871cfb8-396d-4e24-be8e-4f4a3debe7e2/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/8871cfb8-396d-4e24-be8e-4f4a3debe7e2&q;}},&q;_name&q;:&q;World Food and Agriculture – Statistical Yearbook 2025&q;,&q;id&q;:&q;8871cfb8-396d-4e24-be8e-4f4a3debe7e2&q;,&q;uuid&q;:&q;8871cfb8-396d-4e24-be8e-4f4a3debe7e2&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;aa2232a8-07d1-4c45-8fc3-0a087d072cfb&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;78857147-fbfa-4a47-b9d3-cefa7ff57882&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-03T16:39:20Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;471694f0-f92e-4f4f-b2d9-95546bfe8c5c&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-03T16:39:20Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;e4000bf3-67bc-418b-8e0d-653b0acc2a35&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;176a06a3-2bae-4623-b38a-ecad63b2c560&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-11-03T16:28:53Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;a30f4cf8-cd78-4738-99a0-5ef825968b90&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;The Statistical Yearbook 2025 offers a synthesis of the major factors at play in the global food and agricultural landscape. Statistics are presented in four thematic chapters, covering the economic importance of agricultural activities, inputs, outputs and factors of production, their implications for food security and nutrition and their impacts on the environment. The Yearbook is meant to constitute a primary tool for policymakers, researchers and analysts, as well as the general public interested in the past, present and future path of food and agriculture.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;e0fbe189-8d72-4fe6-8960-eec05b026173&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;418 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;05e7e1f9-6688-4f66-8a28-df7dbc9795c8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140174-3&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;7a92ab20-b52c-4ba2-95d1-e115543143d8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2225-7373&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;e3327684-76dd-439c-8f6e-25c12787d851&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd4313en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;6d841212-8358-4e9e-a69a-105bc579cea0&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;8a04952c-c495-4ef1-a329-97e7ee1cc75d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;0a396501-8866-46c3-a6b6-fe7c9d141dcb&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO Statistical Yearbook – World Food and Agriculture&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;435b6e04-9a25-44d5-9745-f69efcda866d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;c6cb3040-5fac-41d0-8679-af033cfe980f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;a89aecbc-6a0c-4163-a