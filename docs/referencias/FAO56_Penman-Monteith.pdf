;relationships&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/74d08f97-306a-4653-8ffe-140a2fc4d783/relationships&q;},&q;version&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/74d08f97-306a-4653-8ffe-140a2fc4d783/version&q;},&q;templateItemOf&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/74d08f97-306a-4653-8ffe-140a2fc4d783/templateItemOf&q;},&q;thumbnail&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/74d08f97-306a-4653-8ffe-140a2fc4d783/thumbnail&q;},&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/74d08f97-306a-4653-8ffe-140a2fc4d783/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/74d08f97-306a-4653-8ffe-140a2fc4d783&q;}},&q;_name&q;:&q;The Impact of Disasters on Agriculture and Food Security 2025&q;,&q;id&q;:&q;74d08f97-306a-4653-8ffe-140a2fc4d783&q;,&q;uuid&q;:&q;74d08f97-306a-4653-8ffe-140a2fc4d783&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;5f265ef8-7a87-45c9-bb01-6ff2300298b1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;5afde733-42e5-44ac-bfe0-fdaf0c084617&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-14T10:47:38Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;848541b7-3a28-4356-a8f7-43b9ac988c9e&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-14T10:47:38Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;c1f56295-8204-4fc2-abc0-16940d0b69a2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;0abfe5c0-dfcc-4240-815b-2810c2ad5282&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-11-14T10:43:42Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;3ad8bdbc-d29f-43b1-a12d-c80432029b61&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;This biennial flagship report provides comprehensive evidence on the escalating impact of disasters on global agricultural systems, revealing losses of USD 3.26 trillion over the period 1991–2023. The 2025 edition introduces enhanced methodologies for assessing disaster impacts across crops, livestock, fisheries and aquaculture subsectors, offering Member States robust data for evidence-based policymaking.Aligned with the 2030 Agenda for Sustainable Development and the Sendai Framework for Disaster Risk Reduction, this edition provides actionable recommendations for integrating disaster risk reduction into agricultural policies and investments through digital innovations. From AI-powered early warning systems to mobile-based insurance reaching millions of smallholder farmers, the report demonstrates how technology is revolutionizing agricultural risk management.Yet technology alone isn&s;t the answer. The report emphasizes putting farmers at the centre – designing solutions with them, not for them – while addressing the digital divide that leaves 2.6 billion people offline. Through compelling case studies and actionable frameworks, it provides a roadmap for building resilient agricultural systems capable of feeding the world in an era of mounting climate risks.This publication serves as an essential resource for governments, development partners, and stakeholders working to build resilient agrifood systems in the face of climate change and increasing disaster risks.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;96cb4d1a-bf1c-4839-acbf-7513dde8ed22&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;144 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;5b0ea72c-68f7-49de-bafd-d92471ba41b3&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140181-1&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;c003a470-de7e-43a3-9611-a10bccb2dc76&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140180-4&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;29df9d03-9b40-41ac-805d-abfa55d2ec3e&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd7185en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;eafd011e-2921-4e08-9ead-daa740374b28&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;191802fc-241c-4f20-bb1b-8367fbacbca6&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;cca09445-955b-4cdf-b1a5-fc5b8537b1af&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;dc31a180-f82a-4b44-801d-5ced3181f8c8&q;,&q;language&q;:null,&q;value&q;:&q;CC BY 4.0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;b2922091-3a1e-491d-9450-6fea717a0b8a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;The Impact of Disasters on Agriculture and Food Security 2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitle&q;:[{&q;uuid&q;:&q;70eb1aeb-3ac2-4411-be16-ac86563f06fc&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Digital solutions for reducing risks and impacts&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.type&q;:[{&q;uuid&q;:&q;971da8cc-e916-446f-b657-715a3a0831d5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Book (stand-alone)&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.altmetricbadge&q;:[{&q;uuid&q;:&q;029b4a75-5101-4d1e-86c9-21c22d803760&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Yes&q;,&q