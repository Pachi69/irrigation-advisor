e&q;:[{&q;uuid&q;:&q;068aee7b-9de1-4686-b78a-3dcb71393092&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Book (series)&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.altmetricbadge&q;:[{&q;uuid&q;:&q;d3e68cfb-5ac1-4253-9a57-e928f0884bef&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Yes&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.cardvisibilitytype&q;:[{&q;uuid&q;:&q;1e8bb143-7922-4052-b9a6-bb053e522fed&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Public&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.citation&q;:[{&q;uuid&q;:&q;9d8573bb-515d-459f-826c-6100e020a6a6&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;&l;div class=\&q;ExternalClassE67CE7116A4A48A2A05A0ADF22E632E9\&q;&g;&l;p&g;FAO, IFAD, UNICEF, WFP and WHO. 2025.&a;#160;&l;em&g;The State of Food Security and Nutrition in the World 2025 –&a;#160;Addressing high food price inflation for food security and nutrition&l;/em&g;.&a;#160;Rome.&l;br&g;&l;/p&g;&l;/div&g;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.contentcategory&q;:[{&q;uuid&q;:&q;c86c94bb-e478-402a-b534-bc0f160f90ff&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Flagship&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.date.available&q;:[{&q;uuid&q;:&q;0f794129-5d48-47d2-b249-3c18f642f217&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-07-27T22:00:00Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.embargo&q;:[{&q;uuid&q;:&q;f6208603-d678-475c-ac28-281e20c63ae9&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Yes&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.embargodate&q;:[{&q;uuid&q;:&q;94c0ec95-ff3a-40be-b244-2f2137805ce8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-07-28T14:30:00Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.fasttrack&q;:[{&q;uuid&q;:&q;9e933afe-d3e1-4dac-aff1-386de16eea06&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;No&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.identifier.doi&q;:[{&q;uuid&q;:&q;33493629-a0a5-4c32-879b-7b54deeff8a9&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;https://doi.org/10.4060/cd6008en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.identifier.googlebookurl&q;:[{&q;uuid&q;:&q;90a6219b-074a-4d3a-bf7c-0f4386bbe975&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;https://books.google.it/books/about?id=sQ95EQAAQBAJ&a;redir_esc=y&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.identifier.jobnumber&q;:[{&q;uuid&q;:&q;64549a09-09b2-4433-b883-1f2ec80eee76&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;CD6008EN&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.identifier.pws&q;:[{&q;uuid&q;:&q;b4b6450f-68b0-4d36-a69d-e1e35eee6f4c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;328712&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.initiator&q;:[{&q;uuid&q;:&q;458e1798-67c4-4dd1-b10f-0e0d6639f3a0&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Verona, Daniela (ESA)&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.leadauthoringunit&q;:[{&q;uuid&q;:&q;a2ab2e3f-43e2-4f86-a346-5aaf0fa09a88&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;ESA - Agrifood Economics and Policy&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.occnotes&q;:[{&q;uuid&q;:&q;7eb9bb6b-30cf-41ef-bc95-31fa30c41d3a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;&l;div class=\&q;ExternalClass8EFFBF524B5C407F9782BEBBE5822166\&q;&g;&l;p&g;&l;strong&g;From&a;#58;&l;/strong&g; Copyright &a;lt;Copyright@fao.org&a;gt; &l;br&g;&l;strong&g;Sent&a;#58;&l;/strong&g; Sunday, July 27, 2025 10&a;#58;45 PM&l;br&g; &l;strong&g;To&a;#58;&l;/strong&g; Galeotti, Laura (OCCP) &a;lt;Laura.Galeotti@fao.org&a;gt;&l;br&g;&l;strong&g;Subject&a;#58;&l;/strong&g; Re&a;#58; SOFI 2025 -In Brief DTP8&l;br&g;&l;/p&g;&l;p&g;Dear Laura,&l;br&g;&l;/p&g;&l;p&g;I had sent a separate message yesterday confirming that FAO has no objection to the highlighted proposed text by the partners below&a;#58;&a;#160; (Resending it also from the copyright now and looping in everyone involved for their information)&l;br&g;&l;/p&g;&l;p&g;&l;em style=\&q;background-color&a;#58;#ffff00;\&q;&g;The terminology used to refer to countries, territories and areas as well as the representation of countries, territories and areas, including the delimitation of frontiers or boundaries, in this publication follow the institutional style and practice of FAO as the lead publishing organization, and may be at variance with those used by IFAD, UNICEF, WFP and WHO.&l;/em&g;&l;/p&g;&l;p&g;English version of the In Brief already has this para included, so consider this cleared by the copyright.&a;#160; Kindly make sure that the highlighted section above is also included in the main report, digital report and all other language version of the In Briefs before they are published tomorrow.&l;br&g;&l;/p&g;&l;p&g;If you need anything else from me, please let me know.&l;br&g;&l;/p&g;&l;p&g;Kind regards,&l;/p&g;&l;p&g;Radhika&l;br&g;&l;/p&g;&l;p&g;&l;span style=\&q;color&a;#58;#000000;font-family&a;#58;&a;quot;helvetica neue&a;quot;;\&q;&g;Copyright&a;#58; FAO&l;/span&g;&l;span class=\&q;Apple-converted-space\&q; style=\&q;color&a;#58;#000000;font-family&a;#58;&a;quot;helvetica neue&a;quot;;\&q;&g;&a;#160;&l;/span&g;&l;/p&g;&l;div&g;&l;p class=\&q;p2\&q; style=\&q;line-height&a;#58;normal;font-size-adjust&a;#58;none;font-feature-settings&a;#58;normal;font-stretch&a;#58;normal;font-family&a;#58;&a;quot;helvetica neue&a;quot;;color&a;#58;#000000;\&q;&g;Logo&a;#58; IFAD, UNICEF, WFP and WHO logos cleared&l;/p&g;&l;p class=\&q;p2\&q; style=\&q;line-height&a;#58;normal;font-size-adjust&a;#58;none;font-feature-settings&a;#58;normal;font-stretch&a;#58;normal;font-family&a;#58;&a;quot;helvetica neue&a;quot;;color&a;#58;#000000;\&q;&g;AU&a;#58; FAO,&a;#160;IFAD, UNICEF, WFP and WHO&l;/p&g;&l;p class=\&q;p2\&q; style=\&q;line-height&a;#58;normal;font-size-adjust&a;#58;none;font-feature-settings&a;#58;normal;font-stretch&a;#58;normal;font-family&a;#58;&a;quot;helvetica neue&a;quot;;color&a;#58;#000000;\&q;&g;PU&a;#58; FAO, IFAD, UNICEF, WFP and WHO&l;/p&g;&l;p class=\&q;p2\&q; style=\&q;line-height&a;#58;normal;font-size-adjust&a;#58;none;font-feature-settings&a;#58;normal;font-stretch&a;#58;normal;font-family&a;#58;&a;quot;helvetica neue&a;quot;;color&a;#58;#000000;\&q;&g;FAO can sell&a;#58; yes&l;br&g;&l;/p&g;&l;p class=\&q;p2\&q; style=\&q;line-height&a;#58;normal;font-size-adjust&a;#58;none;font-feature-settings&a;#58;normal;font-stretch&a;#58;normal;font-family&a;#58;&a;quot;helvetica neue&a;quot;;color&a;#58;#000000;\&q;&g;FAO doi&a;#58; yes&l;br&g;&l;/p&g;&l;p class=\&q;p2\&q; style=\&q;line-height&a;#58;normal;font-size-adjust&a;#58;none;font-feature-settings&a;#58;normal;font-stretch&a;#58;normal;font-family&a;#58;&a;quot;helvetica neue&a;quot;;color&a;#58;#000000;\&q;&g;CC-BY 4.0 license&l;span class=\&q;Apple-converted-space\&q;&g;&a;#160;&l;/span&g;&l;/p&g;&l;p class=\&q;p2\&q; style=\&q;line-height&a;#58;normal;font-size-adjust&a;#58;none;font-feature-settings&a;#58;normal;font-stretch&a;#58;normal;font-family&a;#58;&a;quot;helvetica neue&a;quot;;color&a;#58;#000000;\&q;&g;&l;span class=\&q;Apple-converted-space\&q;&g;Additional text on copyright disclaimer cleared&l;/span&g;&l;/p&g;&l;/div&g;&l;p&g;&l;a href=\&q;/&a;#58;b&a;#58;/s/OCCP/EcbFLLFiA4xBg-SSy8TiNMoBFvPBZwbQqBcmUxpfVWzvvw?e=lfulf7\&q;&g;18.ESA.WHO-IFAD-UNICEF-WFP SOFI UMBRELLA signed by all the Partners.pdf&l;/a&g;&l;br&g;&l;/p&g;&l;div&g;&l;span class=\&q;Apple-converted-space\&q;&g;&l;a href=\&q;/&a;#58;b&a;#58;/s/OCCP/EXsmK-GkmwBPjpeMdgXG8SYB6NoFwz9Ad9VyalFZRY9bOQ?e=XZspfT\&q; style=\&q;color&a;#58;#0056b3;text-decoration-line&a;#58;underline;\&q;&g;18.ESN.SOFI addendum WHO IFAD UNICEF_FAO_WFP.pdf&l;/a&g;&l;br&g;&l;/span&g;&l;/div&g;&l;/div&g;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.otherentitiesinvolved&q;:[{&q;uuid&q;:&q;e3f22632-627e-454f-a8f5-54d4fa4a8cfa&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;#21734;&q;,&q;place&q;:0