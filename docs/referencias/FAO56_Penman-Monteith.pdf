&q;e694df19-1039-43b7-8d7a-af2a46e000bb&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;4577f17f-c967-424f-84b5-4413d4c05265&q;,&q;language&q;:null,&q;value&q;:&q;2026-03-06T14:42:00Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;c1635782-aedd-49f6-99b9-ad941879b4af&q;,&q;language&q;:null,&q;value&q;:&q;2026-03-06T14:42:00Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;efde7514-7a90-4bba-9f03-b6831a59cdc2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2024&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;e9b9ecd9-c631-4b15-bd49-e90938e3f678&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-03-06T14:36:00Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;78732792-6c62-4ab0-ad73-41ade257918f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;تولي طبعة عام 2024 من تقرير حالة الموارد السمكية وتربية الأحياء المائية في العالم، أهمية خاصة لتنفيذ التحوّّل الأزرق على أرض الواقع من خلال أنشطة ومبادرات تقودها المنظمة بالتعاون مع الأعضاء والشركاء وأصحاب المصلحة الرئيسيين وتهدف إلى دمج الأغذية المائية في الأمن الغذائي العالمي والاستدامة، وتحسين الدعوة في مجال السياسات، والبحوث العلمية وبناء القدرات، ونشر الممارسات المستدامة والابتكارات التكنولوجية، ودعم مشاركة المجتمعات المحلية. ويستفيد الجزء الأول من هذا الإصدار من تقرير حالة الموارد السمكية وتربية الأحياء المائية في العالم من التحسينات الكبرى التي تحققت في مجال جمع البيانات، وأدوات التحليل والتقييم، والمنهجيات المتبعة، لعرض أحدث استعراض لإنتاج مصايد الأسماك وتربية الأحياء المائية في العالم واستخدامه. ويسلّّط الجزء الثاني الضوء على دور المنظمة وشركائها في تحفيز التغيّّرات التحوّّلية اللازمة لدعم توسيع نطاق تربية الأحياء المائية وتكثيفها، والإدارة الفعالة لمصايد الأسماك العالمية، وتطوير سلاسل القيمة المائية. ويتناول الجزء الثالثالتحديات والفرص العالية التأثير التي تنطوي عليها الإمكانات غير المستغلة لاستخدام الأسماك كاملة ومشتقاتها من أجل تحسين الأمن الغذائي والتغذية، ويشرح دور نظم الأغذية المائية في توفير حلول حاسمة ومؤاتية للمناخ والتنوع البيولوجي والبيئية، ويسلّّط الضوء على أهمية دمج هذه الحلول في العمليات الوطنية والمتعددة الأطراف. ويعرض الجزء الثالث أيضًًا نظرة استشرافية على الاتجاهات المستقبلية حتى عام 2032 بناءًً على الإسقاطات المتاحة.ويقدّّم تقرير حالة الموارد السمكية وتربية الأحياء المائية في العالم 2024 أحدث المعلومات القائمة على الأدلة، والسياسات الداعمة، والرؤى العلمية والتقنية حول التحديات والفرص والابتكارات التي ترسم ملامح القطاع اليوم وفي المستقبل لخدمة جمهور واسع ومتزايد من واضعي السياسات، والمديرين، والعلماء، والصيادين، ومزارعي الأسماك، والتجار، والناشطين في المجتمع المدني، والمستهلكين.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;6c329e37-69b9-40a3-a0fe-37b751da45dd&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;262 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;30db1bdb-070a-4487-9357-0361b812cd07&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138809-9&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1},{&q;uuid&q;:&q;7110576c-917d-44a1-94c4-46bd5c898d2b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138810-5&q;,&q;place&q;:1,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;846b7f29-19b8-4acb-aa6e-1998008e95e8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2663-8665&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;12fddea1-ce05-4e55-aab6-a62d0c5ab20d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138808-2&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;5f08bf15-713d-4bc4-9d06-7899dafbd7b1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;1020-5519&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;1396a209-36b1-4b87-be80-1e682c820a72&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd0683ar&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;dc5b99c8-0834-475a-a63a-1fe482ac47a6&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Arabic&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;18ada64c-2627-45da-95f3-2ffd493d0cbd&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;منظمة الأغذية والزراعة ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;155b80d5-fccb-4fea-81e2-4680b5895d07&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;حالة الموارد السمكية وتربية الأحياء المائية في العالم&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;0d973a4c-0746-4add-8842-f5670bd62f5b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2024&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;7771dd1e-ded7-471a-9aea-53e94ad11806&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;1eab370a-59b3-460b-b253-2bd0d503f106&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;CC BY NC SA 3.0 IGO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;866d2cbe-26ef-4d5e-988d-9683ecb23c20&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;حالة الموارد السمكية وتربية الأحياء المائية في العالم 2024&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.englishtranslation&q;:[{&q;uuid&q;:&q;21b48f55-eaad-49a7-bc64-fba91cef062f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;The State of World Fisheries and Aquaculture&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitle&q;:[{&q;uuid&q;:&q;3eb21546-c21f-4b4a-acd4-b733835ecf29&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;التحول الأزرق في ميدان العمل&q;,&q;place&q;