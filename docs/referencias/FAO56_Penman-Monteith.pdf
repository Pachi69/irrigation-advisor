q;fao.fasttrack&q;:[{&q;uuid&q;:&q;8430c9c5-2efa-4967-943e-f84c54b153e4&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;No&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.identifier.doi&q;:[{&q;uuid&q;:&q;0ca6fa0a-8e56-4861-ad32-c6140ed42494&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;https://doi.org/10.4060/cd6008es&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.identifier.jobnumber&q;:[{&q;uuid&q;:&q;fd92c90f-0534-4852-b6b5-e555be9870bb&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;CD6008ES&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.identifier.pws&q;:[{&q;uuid&q;:&q;a3ab86dd-4344-44fa-bdd7-2e6a88b20b33&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;331660&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.initiator&q;:[{&q;uuid&q;:&q;d0c3bccd-4ff6-4e95-98d0-5cb403beabd2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Verona, Daniela (ESA)&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.leadauthoringunit&q;:[{&q;uuid&q;:&q;446d0adb-3a84-4b82-bf45-ea2426d617c7&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;ESA - Agrifood Economics and Policy&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;fao.occnotes&q;:[{&q;uuid&q;:&q;8b2637aa-ced6-44bd-891a-3e8771507f90&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;&l;div class=\&q;ExternalClassDB602A5007704565A6F8DF786648EDF0\&q;&g;&l;p&g;Copied from the English record&a;#58;&l;br&g;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;Dear Laura,&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&a;#160;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;I had sent a separate message yesterday confirming that FAO has no objection to the highlighted proposed text by the partners below&a;#58;&a;#160; (Resending it also from the copyright now and looping in everyone involved for their information)&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&a;#160;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&l;em style=\&q;background-color&a;#58;#ffff00;\&q;&g;The terminology used to refer to countries, territories and areas as well as the representation of countries, territories and areas, including the delimitation of frontiers or boundaries, in this publication follow the institutional style and practice of FAO as the lead publishing organization, and may be at variance with those used by IFAD, UNICEF, WFP and WHO.&l;/em&g;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&a;#160;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;English version of the In Brief already has this para included, so consider this cleared by the copyright.&a;#160; Kindly make sure that the highlighted section above is also included in the main report, digital report and all other language version of the In Briefs before they are published tomorrow.&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&a;#160;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;If you need anything else from me, please let me know.&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&a;#160;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;Kind regards,&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;Radhika&l;br&g;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&l;br&g;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&l;br&g;&l;/p&g;&l;p style=\&q;margin-bottom&a;#58;10px;line-height&a;#58;1.6;\&q;&g;&l;span style=\&q;color&a;#58;#000000;font-family&a;#58;&a;quot;helvetica neue&a;quot;;\&q;&g;Copyright&a;#58; FAO&l;/span&g;&l;span class=\&q;Apple-converted-space\&q; style=\&q;color&a;#58;#000000;font-family&a;#58;&a;quot;helvetica neue&a;quot;;\&q;&g;&a;#160;&l;/span&g;&l;/p&g;&l;div&g;&l;p class=\&q;p2\&q; s