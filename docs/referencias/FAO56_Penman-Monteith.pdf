er/api/core/items/596e5d9e-494e-4f96-8feb-ac80aeae2b6d/templateItemOf&q;},&q;thumbnail&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/596e5d9e-494e-4f96-8feb-ac80aeae2b6d/thumbnail&q;},&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/596e5d9e-494e-4f96-8feb-ac80aeae2b6d/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/596e5d9e-494e-4f96-8feb-ac80aeae2b6d&q;}},&q;_name&q;:&q;FPMA 简报 #3 CH, 2026年4月13日&q;,&q;id&q;:&q;596e5d9e-494e-4f96-8feb-ac80aeae2b6d&q;,&q;uuid&q;:&q;596e5d9e-494e-4f96-8feb-ac80aeae2b6d&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;49ff0de6-3b80-46da-b98f-def6d8bcd941&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.coverage.spatial&q;:[{&q;uuid&q;:&q;63d71f54-a0e4-444a-85ed-b6ce32d83100&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;World&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;a45490f0-3f27-432a-9a90-09d008aca371&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-17T10:25:21Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;9534bfa2-3b92-450a-88af-5a1e5115cbe4&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-17T10:25:21Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;08f5f37b-0566-4c69-ab1e-13c71ee4cd5c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;504453bd-07a1-4037-b2f8-e521c2ec50d5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-04-17T10:23:41Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;66327c89-e48c-42b4-b329-870757b9ef2d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;3月，全球玉米供应充足，价格总体保持稳定，但各地区价格走势不一。各出口国的小麦价格普遍上涨，原因是市场担忧天气状况，能源价格上涨，以及投入品价格走高带来种植不确定性。国际稻米价格下跌，原因是收成压力、进口需求疲软、以及汇率波动。2026年2月和3月，在受粮农组织监测的国内市场中，季节性因素是导致主粮价格环比波动的主要原因。稻米价格总体稳定或下跌，而小麦价格走高，原因是国际市场价格变动。受局部地区供需状况的影响，粗粮价格波动较大。在东非和近东多个国家，冲突、天气不利以及宏观经济形势严峻继续支撑主粮价格维持在高位。近东地区冲突升级为国内主粮市场价格带来上行压力。因此，多国已采取针对性措施，缓解可能的价格冲击。本轮价格上涨主要受能源成本攀升、供应链中断以及宏观经济压力驱动。&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;df10d4a7-3665-40ec-84e0-d3ef9723e34f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;4&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;b326d5bc-134f-4716-93c0-d33e7cf171e3&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-2053&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;574598ce-636e-41a8-a125-e119f80b00f5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-2045&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;6bdf819e-2d01-4728-873a-372f3c2915f4&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd9328zh&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;6c33af7b-a7c4-485b-aa7d-6570517d2f20&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Chinese&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;322438ef-f9e6-47ca-8b3a-7bd94930e513&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;粮农组织 ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;aae9db40-31c5-45ed-b1c9-8b9a0c87ee50&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FPMA 简报&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;1cc8ba89-0bc4-46ca-961f-173b6afc0c46&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;03/2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;2a88c860-e9de-4b3f-8c41-8d321b44d94e&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;