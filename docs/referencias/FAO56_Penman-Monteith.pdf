edCollections&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a/mappedCollections&q;},&q;owningCollection&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a/owningCollection&q;},&q;relationships&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a/relationships&q;},&q;version&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a/version&q;},&q;templateItemOf&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a/templateItemOf&q;},&q;thumbnail&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a/thumbnail&q;},&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/808b1067-ca93-418a-9f08-6582ae7d365a&q;}},&q;_name&q;:&q;La Situation mondiale des pêches et de l’aquaculture 2024&q;,&q;id&q;:&q;808b1067-ca93-418a-9f08-6582ae7d365a&q;,&q;uuid&q;:&q;808b1067-ca93-418a-9f08-6582ae7d365a&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;e73381f6-2c63-47fe-a791-49247c65c24a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;75ab90f5-c1a1-4800-aba9-9b7a41acfa03&q;,&q;language&q;:null,&q;value&q;:&q;2026-03-06T17:00:57Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;76f770fe-03f5-4653-87bf-f6621df8669b&q;,&q;language&q;:null,&q;value&q;:&q;2026-03-06T17:00:57Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;ac8484cf-3e19-46bf-a411-66165405154b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2024&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;a65ea90e-52d4-4e75-9b4e-d3cfe07860c2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-03-06T16:58:28Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;c0c67ffe-8d6c-4fbc-9dba-dec6e5581912&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;L’édition 2024 de La Situation mondiale des pêches et de l’aquaculture met à l’honneur la transformation bleue en action, qui prend corps dans les activités et les initiatives menées par la FAOen collaboration avec les membres, les partenaires et les principales parties prenantes. Elle vise la prise en compte des produits alimentaires aquatiques dans la sécurité et la durabilité alimentaires mondiales, le développement des activités de promotion des politiques et de recherche scientifique, ainsi que le renforcement des capacités, la diffusion des pratiques durables et des innovations technologiques, et l’appui à la participation des communautés.La première partie de la présente édition de La Situation mondiale des pêches et de l’aquaculture fait fond sur les améliorations considérables apportées aux outils et aux méthodes de collecte, d’analyse et d’évaluation des données afin de présenter l’évaluation la plus récente de la production et de l’utilisation des pêches et de l’aquaculture dans le monde. La deuxième partie porte sur le rôle de la FAO et de ses partenaires pour ce qui est de catalyser les changements porteurs de transformation qu’il faut opérer afin de favoriser l’expansion et l’intensification de l’aquaculture, une gestion efficace des pêches mondiales et la modernisation des chaînes de valeur des produits aquatiques.La troisième partie est consacrée aux défis et aux possibilités liés au potentiel inexploité des poissons entiers et de leurs sous-produits pouvant améliorer la sécurité alimentaire et la nutrition, et qui sont susceptibles d’avoir un fort impact dans ce domaine. Cette partie décrit le rôle des systèmes alimentaires aquatiques dans la recherche de solutions cruciales qui soient respectueuses du climat, de la biodiversité et de l’environnement, et souligne combien il est important de prendre en compte ces systèmes dans les processus nationaux et multilatéraux. Elle donne aussi un aperçu des évolutions qui se profilent à l’horizon 2032, compte tenu des projections.L’édition 2024 de La Situation mondiale des pêches et de l’aquaculture présente les informations les plus récentes, fondées sur des éléments factuels, et apporte des éclairages stratégiques,scientifiques et techniques sur les défis, les possibilités et les innovations qui déterminent le présent et l’avenir de ce secteur. Elle s’adresse à un éventail large et grandissant de décideurs, degestionnaires, de scientifiques, de pêcheurs, d’agriculteurs, de commerçants, de militants de la société civile et de consommateurs.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;c910779c-507d-45b6-86a3-f8c6bc38295d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;282 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;d4cef3ee-53f4-4920-b508-0526787d0892&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138815-0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1},{&q;uuid&q;:&q;9c8b80db-48e8-4b3f-82c1-d9bf50e7bd21&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138816-7&q;,&q;place&q;:1,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;0f19e3eb-4855-4390-b824-3fd1d797a5be&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2663-8371&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;657648dd-66a2-4721-96fa-c7c546fec187&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-138814-3&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;u