,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;3aa45bc2-5535-469e-b29b-23b59657fce7&q;,&q;language&q;:null,&q;value&q;:&q;2026-02-02T10:17:27Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;55508a4a-ccaa-41b5-8ee0-08d164ed2f6e&q;,&q;language&q;:null,&q;value&q;:&q;2026-02-02T10:17:27Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;b9b44c18-646e-4238-a9ab-06dc3403505f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;18f7ca11-1d5f-4131-8f2f-ecfbba2d5cef&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-02-02T10:11:51Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;849c894f-1b40-4482-8252-4459735735b3&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;The 2025 edition of The State of Food and Agriculture explores the theme “Addressing land degradation across landholding scales”. It examines the implications of human-induced land degradation for agricultural production, producers of all scales and vulnerable populations. The report presents new findings on how cropland degradation contributes to the yield gap worldwide against a backdrop of broader degradation processes on other land cover types and even land abandonment. Drawing on the latest data on global farm distribution, farm sizes and crop production, the report highlights how the scale at which land is managed shapes both the constraints and the opportunities for adopting sustainable land use and management practices. It also underscores the importance of policymaking that encompasses regulatory and incentive-based measures, tailored to the varied conditions and scales of land use, to avoid, reduce and reverse land degradation.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;04cceb9b-7a14-4654-9ec0-27890179176b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;148 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;969e3760-a499-4581-9f31-7944610dc377&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140143-9&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;5a105bce-daf4-47bf-8437-7965bbf32f95&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;1564-3352&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;cd6d8790-9c7a-4a24-95e9-da10048ec02a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140142-2&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;232cbe8b-0809-443c-8043-a25b8262bc86&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;0081-4539&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;125bbc43-d161-4b19-bf35-8cea28974f22&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd7067en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;193e9972-4994-4ee0-ba32-ce2649d67ce1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;e8ac8959-30e2-4b25-816d-c5633594a642&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;e6d5f3ee-847b-4c07-9db0-7502ea206371&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;The State of Food and Agriculture (SOFA)&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;b3aa78a4-bd0b-4536-8c1f-57c6c1b166c3&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;N.A.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q