;:[{&q;uuid&q;:&q;454c341d-85f1-4852-b6be-4881e9b8216c&q;,&q;language&q;:null,&q;value&q;:&q;2023-04-27T13:32:29Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;6e11fb1d-bbe9-40c8-b2b3-035b12cb64b2&q;,&q;language&q;:null,&q;value&q;:&q;2021&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;2d5c60cb-3243-4623-afd7-9f6e603f03ce&q;,&q;language&q;:null,&q;value&q;:&q;2021-05-04T05:44:30.0000000Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;f7ef3f6a-f097-48f9-b194-4b919d873aa1&q;,&q;language&q;:null,&q;value&q;:&q;ФАО завершила свою первую оценку мировых лесных ресурсов в 1948 году. В то время ее основной задачей был сбор информации об имеющихся предложениях древесины для удовлетворения спроса на послевоенное восстановление. С тех пор Глобальная оценка лесных ресурсов (ОЛР) превратилась во всеобъемлющую оценку лесных ресурсов и их состояния, управления и использования, охватывающую все тематические элементы устойчивого управления лесами.\nВ этой последней из этих оценок изучаются состояние и тенденции развития лесных ресурсов за период 1990–2020 годов с привлечением усилий сотен экспертов по всему миру. Подготовка ОЛР-2020 также предполагала сотрудничество многих партнерских организаций, что снизило нагрузку на страны по отчетности, повысило синергию между процессами отчетности и повысило согласованность данных.\nРезультаты ОЛР-2020 доступны в нескольких форматах, включая этот отчет и онлайн-базу данных, содержащую исходные данные стран и территорий, а также кабинетные исследования и региональные и глобальные анализы, подготовленные ФАО. Я приглашаю вас использовать эти материалы для поддержки нашего общего пути к более устойчивому будущему с лесами.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;02ad0512-0de8-46aa-a487-4bc19206db37&q;,&q;language&q;:null,&q;value&q;:&q;184 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;7723f5c1-2e8b-4c71-8b61-80766f962124&q;,&q;language&q;:null,&q;value&q;:&q;978-92-5-134154-4&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;97d0186c-6ca7-4f02-bb56-be1a51218e68&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/ca9825ru&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;552bb4ce-eb08-4935-ae02-09ac73cc776b&q;,&q;language&q;:null,&q;value&q;:&q;http://www.fao.org/3/ca9825ru/ca9825ru.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;9e28e329-81b0-4247-b812-c45c21e6cb02&q;,&q;language&q;:null,&q;value&q;:&q;Russian&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;165014f1-e130-4895-b66f-87b938ae875c&q;,&q;language&q;:null,&q;value&q;:&q;ФАО ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;32ef526a-fbd8-47bf-af6b-5af17556c3e7&q;,&q;language&q;:null,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;5d954d73-821e-444e-88f7-b37248f95aa6&q;,&q;language&q;:null,&q;value&q;:&q;CC BY NC SA 3.0 IGO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;97288bf5-bfac-4fec-b499-779e06698608&q;,&q;language&q;:null,&q;value&q;:&q;Глобальная оценка лесных ресурсов 2020 года&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.englishtranslation&q;:[{&q;uuid&q;:&q;3914cb1a-7a64-468b-aba7-bcc0535b8fa5&q;,&q;language&q;:null,&q;value&q;:&q;Global Forest Resources Assessment 2020&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitle&q;:[{&q;uuid&q;:&q;26f3079f-ee29-402e-ac5d-414039869d00&q;,&q;language&q;:null,