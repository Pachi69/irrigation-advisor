ge&q;:null,&q;value&q;:&q;2023-04-27T13:32:29Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;d6cf9796-ea92-4020-92fa-460d4c1cc65f&q;,&q;language&q;:null,&q;value&q;:&q;2021&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;70ddbdb8-7f05-47e2-9ffd-db1e066c1439&q;,&q;language&q;:null,&q;value&q;:&q;2021-05-13T13:49:03.0000000Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;ae58553d-c047-42c9-bcb7-1f2d6b26a15f&q;,&q;language&q;:null,&q;value&q;:&q;أكملت منظمة الأغذية والزراعة تقييمها الأول لموارد الغابات في العالم في عام 1948. وكان هدفها الرئيسي في ذلك الوقت هو جمع المعلومات عن إمدادات الأخشاب المتاحة لتلبية الطلب على إعادة الإعمار بعد الحرب. منذ ذلك الحين ، تطور التقييم العالمي لموارد الغابات (FRA) إلى تقييم شامل لموارد الغابات وحالتها وإدارتها واستخداماتها ، وتغطي جميع العناصر الموضوعية للإدارة المستدامة للغابات.\nهذا ، وهو أحدث هذه التقييمات ، يبحث في حالة واتجاهات موارد الغابات خلال الفترة 1990-2020 ، بالاعتماد على جهود مئات الخبراء في جميع أنحاء العالم. تضمن إصدار تقرير تقييم الموارد الحرجية لعام 2020 أيضًا التعاون بين العديد من المنظمات الشريكة ، وبالتالي تقليل عبء الإبلاغ على البلدان ، وزيادة التآزر بين عمليات الإبلاغ ، وتحسين اتساق البيانات.\nتتوفر نتائج تقييم الموارد الحرجية لعام 2020 في عدة أشكال ، بما في ذلك هذا التقرير وقاعدة بيانات على الإنترنت تحتوي على المدخلات الأصلية للبلدان والأقاليم بالإضافة إلى الدراسات المكتبية والتحليلات الإقليمية والعالمية التي أعدتها منظمة الأغذية والزراعة. أدعوكم لاستخدام هذه المواد لدعم رحلتنا المشتركة نحو مستقبل أكثر استدامة مع الغابات.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;da9c5872-185b-45d4-8eb7-b7566659d3b6&q;,&q;language&q;:null,&q;value&q;:&q;184 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;2e313601-d2c2-4029-917e-15f9f1e6faac&q;,&q;language&q;:null,&q;value&q;:&q;978-92-5-134156-8&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;37c85730-d28d-4283-b735-d7781fbb168d&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/ca9825ar&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;026c7770-3595-4576-b79f-ec28f532872d&q;,&q;language&q;:null,&q;value&q;:&q;http://www.fao.org/3/ca9825ar/ca9825ar.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;aaf55a7e-c361-4411-ac49-c2577b847c81&q;,&q;language&q;:null,&q;value&q;:&q;Arabic&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;a505e61f-5e95-4031-a365-758b4b78bdaa&q;,&q;language&q;:null,&q;value&q;:&q;منظمة الأغذية والزراعة ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;808330e3-f870-4522-b99e-77d2d2511ae3&q;,&q;language&q;:null,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;856a7580-b398-44b5-aeae-3510fe0a9d59&q;,&q;language&q;:null,&q;value&q;:&q;CC BY NC SA 3.0 IGO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;96cfe6c9-cf5e-4d80-b136-8634df979a5a&q;,&q;language&q;:null,&q;value&q;:&q;2020 التقييم العالمي لحالة الموارد الحرجية&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.englishtranslation&q;:[{&q;uuid&q;:&q;dc3bf611-a5b8-43a5-afce-e500e75eaf01&q;,&q;language&q;:null,&q;value&q;:&q;Global Forest Resources Assessment 2020&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitle&q;:[{&q;uuid&q;:&q;04a9dd18-d793-4c52-84fd-f00628f4bc10&q;,&q;language&q;:null,&q;value&q;:&q;التقرير الرئيسي&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitleenglishtranslation&q;:[{&q;uuid&q;:&q;ee0a737