,&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564&q;:{&q;data&q;:{&q;handle&q;:&q;20.500.14283/cd7701en&q;,&q;lastModified&q;:&q;2026-03-05T16:00:58.701Z&q;,&q;isArchived&q;:true,&q;isDiscoverable&q;:true,&q;isWithdrawn&q;:false,&q;_links&q;:{&q;bundles&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/bundles&q;},&q;mappedCollections&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/mappedCollections&q;},&q;owningCollection&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/owningCollection&q;},&q;relationships&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/relationships&q;},&q;version&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/version&q;},&q;templateItemOf&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/templateItemOf&q;},&q;thumbnail&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/thumbnail&q;},&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/a4b60529-906f-4c6b-a671-c91f9f827564&q;}},&q;_name&q;:&q;The State of Mediterranean and Black Sea Fisheries 2025&q;,&q;id&q;:&q;a4b60529-906f-4c6b-a671-c91f9f827564&q;,&q;uuid&q;:&q;a4b60529-906f-4c6b-a671-c91f9f827564&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;f5258602-a148-4b92-9b1d-b8c7f21d5d6d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;7a74ede5-2134-482f-b2f4-463098d795d9&q;,&q;language&q;:null,&q;value&q;:&q;2026-02-04T12:36:57Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;b2768f79-4dc9-4715-9945-fb371fe682f1&q;,&q;language&q;:null,&q;value&q;:&q;2026-02-04T12:36:57Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;4bdd2b51-d3f2-4de2-893f-c9cb26461185&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;f3bf3bbd-6673-44b8-bd97-10fb24275379&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-02-04T12:21:32Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;5a36f02d-9468-403f-876b-82b163e1a6b1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;This 2025 edition of the GFCM flagship publication The State of Mediterranean and Black Sea Fisheries presents the most comprehensive and up-to-date review of fisheries and aquaculture status and trends in the Mediterranean and Black Sea region. The sixth installment of this report is the most ambitious to date and comes as a result of an unprecedented collaborative effort across the region. It reflects incremental scientific work, strengthened monitoring and significant innovations in data collection and analysis. The State of Mediterranean and Black Sea Fisheries 2025 expands temporal coverage and incorporates new data on both fisheries and aquaculture, providing a clear and accurate picture of trends and challenges across the region and assessing progress towards the targets set by the GFCM 2030 Strategy for sustainable fisheries and aquaculture in the Mediterranean and the Black Sea. The report begins with an overview of aquatic food systems in the Mediterranean and the Black Sea, before diving into a detailed analysis of capture fisheries production, bycatch and the status of fisheries resources in Chapters one through three. Chapter four explores the rapidly expanding aquaculture sector in the region. Chapter five examines the human dimension of fisheries and aquaculture through socioeconomic data and Chapters six and seven highlight the measures taken and the efforts needed to secure the sustainability of fisheries and aquaculture in the region. This report aims to provide objective, accurate and complete information to support evidence-based decision-making, monitor progress towards sustainability goals and inspire renewed commitments.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;2989310b-f818-4d5a-b169-136d9869759c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;204 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;053c74d7-2564-4063-84c8-8686cf4b4c85&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2413-7049&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;215b29c2-0f3b-4158-a4ae-1bc37786594f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140318-1&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;829c30d9-3b3a-42c4-a2e8-333145411133&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2413-6905&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;cb5fcc83-370e-4fd5-90ca-6ac9b321afaf&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd7701en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;c90e3050-61ae-4adc-a185-eab5e4b18db5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;cce1383c-2fc8-4dcf-8566-5cc901719492&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;ca933da5-dd70-414