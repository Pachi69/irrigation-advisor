or.author&q;:[{&q;uuid&q;:&q;bf758e26-3eb3-4587-8d20-37159f76ff9d&q;,&q;language&q;:null,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;60f80bf0-5f09-494d-a79b-eda32fcaad22&q;,&q;language&q;:null,&q;value&q;:&q;2023-04-27T13:25:35Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;b77b7595-bba3-441c-9d7a-bacfef372a9a&q;,&q;language&q;:null,&q;value&q;:&q;2023-04-27T13:25:35Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;aa310e28-4d32-49c2-81b9-f83f04565d7a&q;,&q;language&q;:null,&q;value&q;:&q;2021&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;29278cb6-37ed-4805-9e3f-bc90cef4fcca&q;,&q;language&q;:null,&q;value&q;:&q;2022-02-07T10:59:16.0000000Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;6dda4c13-7c64-4cbe-a639-5744689dee4a&q;,&q;language&q;:null,&q;value&q;:&q;La FAO a achevé sa première évaluation des ressources forestières mondiales en 1948. À cette époque, son principal objectif était de recueillir des informations sur l’offre de bois disponible pour satisfaire la demande de reconstruction d’après-guerre. Depuis lors, l&s;Évaluation des ressources forestières mondiales (FRA) est devenue une évaluation complète des ressources forestières et de leur état, de leur gestion et de leurs utilisations, couvrant tous les éléments thématiques de la gestion durable des forêts.\nCette dernière, la dernière de ces évaluations, examine l&s;état et les tendances des ressources forestières au cours de la période 1990-2020, en s&s;appuyant sur les efforts de centaines d&s;experts dans le monde. La production de FRA 2020 impliquait également une collaboration entre de nombreuses organisations partenaires, réduisant ainsi le fardeau des rapports pour les pays, augmentant les synergies entre les processus de rapport et améliorant la cohérence des données.\nLes résultats de FRA 2020 sont disponibles dans plusieurs formats, y compris ce rapport et une base de données en ligne contenant les contributions originales des pays et territoires ainsi que des études documentaires et des analyses régionales et mondiales préparées par la FAO. Je vous invite à utiliser ces matériaux pour soutenir notre cheminement commun vers un avenir plus durable avec les forêts.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;a72f2643-83c4-408d-8b87-9f776d4287c6&q;,&q;language&q;:null,&q;value&q;:&q;184 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;6eff1f5a-4e95-492b-a911-ce5a9218e698&q;,&q;language&q;:null,&q;value&q;:&q;978-92-5-134306-7&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;b85e82ed-0fad-4066-899a-f32644b5dbbf&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/ca9825fr&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;87d7ca17-ae45-497b-914e-61ad5b39dfd6&q;,&q;language&q;:null,&q;value&q;:&q;http://www.fao.org/3/ca9825fr/ca9825fr.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;3160aa64-8ea2-4117-a5f1-a5cdd25e1217&q;,&q;language&q;:null,&q;value&q;:&q;French&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;3a0c1daa-8862-4aab-a10d-ccd80823fcfe&q;,&q;language&q;:null,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;4cc86148-0547-4180-b347-0b30865820ef&q;,&q;language&q;:null,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;fe3e71cd-dc43-4000-b71b-e3a0313941ab&q;,&q;language&q;:null