,&q;lastModified&q;:&q;2026-02-10T14:28:49.632Z&q;,&q;isArchived&q;:true,&q;isDiscoverable&q;:true,&q;isWithdrawn&q;:false,&q;_links&q;:{&q;bundles&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/bundles&q;},&q;mappedCollections&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/mappedCollections&q;},&q;owningCollection&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/owningCollection&q;},&q;relationships&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/relationships&q;},&q;version&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/version&q;},&q;templateItemOf&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/templateItemOf&q;},&q;thumbnail&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/thumbnail&q;},&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/9a576e6b-faa7-414a-919f-8265bc6196c3&q;}},&q;_name&q;:&q;El estado de la seguridad alimentaria y la nutrición en el mundo 2025&q;,&q;id&q;:&q;9a576e6b-faa7-414a-919f-8265bc6196c3&q;,&q;uuid&q;:&q;9a576e6b-faa7-414a-919f-8265bc6196c3&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;03d5eb72-414e-465e-9a6a-ace7088afbc1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO; FIDA; OMS; PMA; UNICEF;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;e1a93cd4-d07c-4454-a5a0-dd8e793f8e69&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-25T12:02:23Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;797f42d6-4a93-466d-b038-8b6bc687b4ab&q;,&q;language&q;:null,&q;value&q;:&q;2025-11-25T12:02:23Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;d55ff13e-c97e-497e-ab8a-0a6eb08f4b30&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;86d6ad7f-f87b-4091-8743-04ee01705752&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-11-25T11:57:04Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;dad76b19-7d24-4da1-a0e3-85f502924577&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Aunque en los últimos años se han registrado avances y cierto grado de recuperación, el mundo sigue por encima de los niveles anteriores a la pandemia de la enfermedad por coronavirus (COVID-19) y alejado de la erradicación del hambre y la inseguridad alimentaria para 2030 (meta 2.1 de los Objetivos de Desarrollo Sostenible [ODS]). Análogamente, pese a ciertos avances en el cumplimiento de las metas mundiales en materia de nutrición, el mundo no va camino de cumplir la meta 2.2 de los ODS. Este impulso se ha visto frenado por una inflación persistente de los precios de los alimentos, entre otros factores.En El estado de la seguridad alimentaria y la nutrición en el mundo 2025 se muestra cómo una inflación elevada ha mermado en muchos países el poder adquisitivo y, sobre todo entre las poblaciones de ingresos bajos, el acceso a dietas saludables. En el informe se documenta la vinculación entre la inflación alta de los precios de los alimentos y los aumentos de la inseguridad alimentaria y la malnutrición infantil. Los grupos vulnerables, incluidos los hogares de ingresos bajos, las mujeres y las comunidades rurales, pueden verse especialmente afectados por la inflación de los precios de los alimentos, lo cual comporta el riesgo de reveses en la lucha contra el hambre y la malnutrición.En respuesta a estas dificultades, y para prevenir futuras conmociones de los precios, en el informe se examinan medidas de políticas adoptadas por los países y se describe lo que se necesita para avanzar. Se destaca la importancia de una aplicación coherente de las políticas fiscales y monetarias para estabilizar los mercados, promover un comercio abierto y resiliente y proteger a las poblaciones vulnerables. Además, se propugnan mejoras en los sistemas de datos y una inversión sostenida en sistemas agroalimentarios resilientes para fomentar la seguridad alimentaria y la nutrición a largo plazo. Estas medidas coordinadas son esenciales para reactivar los avances hacia la meta de poner fin al hambre y la malnutrición para 2030.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;6d8abcaf-9a3b-4bab-8784-64c964c9a8fd&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;252 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;03a28c28-769f-4685-930d-1cd861a16c1b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140213-9&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;89ebbf12-a934-47d4-8530-926cfd4c64b3&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2663-855X&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;f0108b31-6e91-4c94-ae06-341aa168236c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140128-6&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;147907f2-bbc7-4fbb-8e4d-34da15cf3c9d&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2663-8541&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;1e569fbb-89d7-4311-a014-b03868c4070f&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd6008es&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;352a8a67-ee8b-4915-b10d-f84a19a3bf2e&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Spanish&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;39cb1294-6f79-4bff-a35e-2cf1213b51ec&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ; FIDA ; OMS ; PMA ; UNICEF ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;809df2de-bfc2-4087-b5fa-9ddaf0a58bc5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;El estado de la seguridad alimentaria y la nutrición en el mundo&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;df6a0ce8-9e9f-4e3f-b400-d1a82d194af0&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;19cc5a31-c1e8-4b5c-8f9e-1d34c4b6d337&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;ce4061f1-5192-4b07-9eb2-a48c9830f57a&q;,&q;language&q;:null,&q;value&q;:&q;CC BY 4.0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;df95d706-8453-4e91-8524-082ab4569d5a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;El estado de la seguridad alimentaria y la nutrición en el mundo 2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.englishtranslation&q;:[{&q;uuid&q;:&q;581bd84b-ab9c-4fc7-87cc-4f872c0e5ad9&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;The State of Food Security and Nutrition in the World 2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitle&q;:[{&q;uuid&q;:&q;606405f3-f72c-4422-b381-9fa534a1d015&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Hacer frente a la inflación alta de los precios de los alimentos en aras de la seguridad alimentaria y la nutrición&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&