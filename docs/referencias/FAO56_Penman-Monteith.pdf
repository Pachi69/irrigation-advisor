buirá al desarrollo de bosques urbanos y periurbanos que ayuden a las ciudades a resolver sus exigencias actuales y futuras de productos forestales y servicios del ecosistema. Estas directrices contribuirán también a aumentar la sensibilización sobre las contribuciones que los bosques  y los árboles pueden aportar para mejorar la calidad de vida, y sobre su papel fundamental en la sostenibilidad mundial.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;dd271b88-13cc-440e-ad2f-202ef52889af&q;,&q;language&q;:null,&q;value&q;:&q;179 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;5551e366-50dc-48e4-b81c-9884d7c4e37c&q;,&q;language&q;:null,&q;value&q;:&q;2707-0379&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;4c1da458-7545-4651-8f40-56221414faa8&q;,&q;language&q;:null,&q;value&q;:&q;978-92-5-309442-4&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;e2832824-90f7-42bd-9ea6-a3985ed4c28d&q;,&q;language&q;:null,&q;value&q;:&q;1014-2886&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;87b5419b-de51-44d4-8a75-f4b8e7013f0f&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/i6210s&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;4e48a714-013e-4525-a023-ca9c76d50090&q;,&q;language&q;:null,&q;value&q;:&q;http://www.fao.org/3/i6210s/i6210s.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;bcd5aba4-9a53-436e-be35-828fef5a33f2&q;,&q;language&q;:null,&q;value&q;:&q;Spanish&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;aaf7a75d-bb64-4f07-afa7-6b7891a24bdd&q;,&q;language&q;:null,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:n