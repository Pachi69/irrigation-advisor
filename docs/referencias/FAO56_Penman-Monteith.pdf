&q;relateditemlistconfigs&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/090d2fbb-32a6-412b-a3b8-1ce5c5905df2/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/090d2fbb-32a6-412b-a3b8-1ce5c5905df2&q;}},&q;_name&q;:&q;Global Forest Resources Assessment 2025&q;,&q;id&q;:&q;090d2fbb-32a6-412b-a3b8-1ce5c5905df2&q;,&q;uuid&q;:&q;090d2fbb-32a6-412b-a3b8-1ce5c5905df2&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;de54de27-b6ff-43e5-add0-4118f5873b64&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;6783adf7-cc56-4669-ba4a-1b1f3b42dd16&q;,&q;language&q;:null,&q;value&q;:&q;2025-10-21T06:30:26Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;36137692-6971-467f-b69e-0e61b1b78275&q;,&q;language&q;:null,&q;value&q;:&q;2025-10-21T06:30:26Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;b25ee96f-4db4-448c-935a-03f474c8cab2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;64f9b04c-d686-4723-9084-d07e0959fc5c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-10-21T06:26:48Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;0fbf1dc1-df36-4849-9b90-6ed6b2ff5dba&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO completed its first assessment of the world’s forest resources in 1948. Since then, the Global Forest Resources Assessment (FRA) has evolved into a comprehensive evaluation of forest resources and their condition, management and uses, covering all the thematic elements of sustainable forest management. This, the latest of these assessments, examines the status of, and trends in, forest resources over the period 1990–2025, drawing on the efforts of hundreds of experts worldwide. The results of FRA 2025 are available in several formats, including this report, an interactive story on key findings and an online database at https://fra-data.fao.org.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;f6646edc-9a14-4323-93c9-3e6c014659f9&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;210 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;281675df-4395-4943-b3eb-062abd4dbc1f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140082-1&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;16e91205-6f96-48be-871b-e37c61bbc755&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd6709en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;1b35cdd6-0d15-4558-97a5-9368f1935ea6&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;7af38130-e82e-443f-8558-2018482485be&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;60b4f0ea-1830-4d12-a917-e2557cfa0763&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;0e037831-ff46-4969-8e9c-363c44be2535&q;,&q;language&q;:null,&q;value&q;:&q;CC BY 4.0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;2e2e0a13-a887-459d-8677-2dcbb51adc86&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Global Forest Resources Assessment 2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.type&q;:[{&q;uuid&q;:&q;352f1775-45b1-4f21-9abd-8d3b1369c84e&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Book (stand-alone)&q;,&q;place&q;:0,&q;authority&q;:nul