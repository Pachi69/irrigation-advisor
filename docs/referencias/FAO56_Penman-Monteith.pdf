urbaine et périurbaine&q;,&q;id&q;:&q;ea50846d-e874-4e04-8a5f-431aa710d364&q;,&q;uuid&q;:&q;ea50846d-e874-4e04-8a5f-431aa710d364&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;c5df7974-3800-4b64-9d34-722631ce9652&q;,&q;language&q;:null,&q;value&q;:&q;Salbitano, F., Borelli, S., Conigliaro, M. et Chen&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.coverage.spatial&q;:[{&q;uuid&q;:&q;cc7e36d3-894e-42c4-aac1-b6688968f33e&q;,&q;language&q;:null,&q;value&q;:&q;Ghana&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;508dd855-9958-4291-b88c-0ebd2e8657f5&q;,&q;language&q;:null,&q;value&q;:&q;2023-04-27T11:18:18Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;6deedd4a-6c36-46cb-a1a0-786ae4c0ccf3&q;,&q;language&q;:null,&q;value&q;:&q;2023-04-27T11:18:18Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;96d81b28-0341-4438-b94a-6c42947ea63a&q;,&q;language&q;:null,&q;value&q;:&q;2017&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;735caf64-b790-4ddc-9c62-1a8968b9dd9e&q;,&q;language&q;:null,&q;value&q;:&q;2019-07-10T14:58:46.0000000Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;d6fe18e0-7822-4e0c-9477-3f5ffdffbfc2&q;,&q;language&q;:null,&q;value&q;:&q;Même si les villes n&s;occupent actuellement que 2 pour cent de la surface de la planète, leurs habitants utilisent 75 pour cent de ses ressources naturelles; d&s;ici 2050, 70 pour cent de la population mondiale vivra dans les villes et les agglomérations. Le développement urbain durable est donc fondamental pour assurer la bonne qualité de vie de la population mondiale. Lorsqu&s;ils sont bien gérés, les forêts et les arbres dans les villes peuvent apporter des contributions importantes à la planifica tion, à la conception et à la gestion de paysages urbains durables et résilients. Ils peuvent rendre les villes des endroits plus agréables, attirants et sains dans lesquels vivre, ainsi que des endroits plus sûrs, plus prospères et plus variés.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;dfca742e-7adf-4890-8bd5-c465a9f9803d&q;,&q;language&q;:null,&q;value&q;:&q;189 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;7a7124e5-d36c-42f1-9916-6cdba8e26e50&q;,&q;language&q;:null,&q;value&q;:&q;2707-0360&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;4066062f-1147-47b4-9d05-eec82d335469&q;,&q;language&q;:null,&q;value&q;:&q;978-92-5-130074-9&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;0ce445cf-b99d-474d-ab5b-1fd82ff9688c&q;,&q;language&q;:null,&q;value&q;:&q;1014-2894&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;193006a8-e367-48af-b11d-edd0614176bc&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/i6210fr&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;09c529a4-7428-4a23-9b59-0fde75cb155c&q;,&q;language&q;:null,&q;value&q;:&q;http://www.fao.org/3/i6210fr/i6210fr.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;e149a78f-3e85-475e-818e-5b50b6457a7d&q;,&q;language&q;:null,&q;value&q;:&q;French&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;9e9c8be4-9145-4b3f-a223-caf6a224d7c6&q;,&q;language&q;:null,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;e7e28658-2370-4007-a171-eef434408692&q;,&q;language&q;:null,&q;value&q;:&q;Étude FAO: Forêts&q;,