//openknowledge.fao.org/server/api/core/items/edcd537b-2e0e-4f0b-9b04-74518c1224ec&q;}},&q;_name&q;:&q;The Second Report on the State of the World&s;s Forest Genetic Resources&q;,&q;id&q;:&q;edcd537b-2e0e-4f0b-9b04-74518c1224ec&q;,&q;uuid&q;:&q;edcd537b-2e0e-4f0b-9b04-74518c1224ec&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;30f68dc2-6054-4982-870c-a03ca42900fc&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;36b271b9-8153-4291-9427-3bfcf59a188f&q;,&q;language&q;:null,&q;value&q;:&q;2025-09-05T15:48:49Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;132661f7-71a1-4495-a598-ceaf9b4c1642&q;,&q;language&q;:null,&q;value&q;:&q;2025-09-05T15:48:49Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;8be1e749-0b61-4c8f-963e-6adc27eff8ad&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;658d1a05-0d05-4704-b3f7-0eacad78c5f2&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025-09-05T15:42:31Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;38e73d3e-5c5c-4223-9a4b-60bec3714bf5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Forests and woodlands provide a huge array of essential benefits for people and the planet – such as hosting biodiversity, supporting livelihoods, protecting soils, regulating water cycles and mitigating climate change. At the heart of such benefits are forest genetic resources: the heritable materials maintained within and among tree and other woody plant species that are of actual or potential economic, environmental, scientific or societal value. These genetic resources underpin the resilience, adaptability and productivity of forests and other tree-based systems, enabling them to withstand environmental stresses and thereby continue providing vital ecosystem services.Drawing on data and information from 77 countries representing more than three-quarters of the world’s forests, The Second Report on the State of the World’s Forest Genetic Resources provides a global assessment of forest genetic resources. It highlights the crucial role of these resources for sustainable development and examines progress in implementing the Global Plan of Action for the Conservation, Sustainable Use and Development of Forest Genetic Resources. The report reviews scientific advances and concludes with recommendations for continued action at the national, regional and global levels to ensure that forest genetic resources are sustainably managed for the benefit of current and future generations.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;b9546898-87d5-47a4-959d-e0604efc4945&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;260 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;73124f11-738f-44f5-ad91-725b594e5cc0&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2412-5482&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;77061f5c-221e-4a08-a9a9-21e35c4ec7a4&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-139699-5&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;ea284d8a-cfe9-4b2f-abe2-31b916b39c18&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2412-5474&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;30320470-f7f5-4f12-8bfd-abfce3c2c6f3&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd4838en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;25000434-3880-4dc9-87b1-feacbcbeeee7&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;: