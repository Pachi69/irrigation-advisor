o.org/server/api/core/items/4b1f7d26-267d-4a81-aed4-4f9de4d93f85/relateditemlistconfigs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/4b1f7d26-267d-4a81-aed4-4f9de4d93f85&q;}},&q;_name&q;:&q;The State of Food Security and Nutrition in the World 2025&q;,&q;id&q;:&q;4b1f7d26-267d-4a81-aed4-4f9de4d93f85&q;,&q;uuid&q;:&q;4b1f7d26-267d-4a81-aed4-4f9de4d93f85&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;fae64bc6-aacd-4b55-b8f5-4c631e9919c0&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO; IFAD; UNICEF; WFP; WHO;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;4cea98eb-7687-4e98-869b-60c4bbf7b2d9&q;,&q;language&q;:null,&q;value&q;:&q;2026-02-19T10:31:34Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;f3966d46-3395-4619-a65d-1f43e4c5fea9&q;,&q;language&q;:null,&q;value&q;:&q;2026-02-19T10:31:34Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;8f642804-d66a-4252-ace2-5fff965f4f64&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2025&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;2579ac67-ceb8-41ee-9f47-d1101ec4abda&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-02-19T10:29:24Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;8e313111-fc6b-49d6-b367-cb55daf235f8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;While some progress and recovery have been made in recent years, the world is still above pre-COVID-19 pandemic levels and far from eradicating hunger and food insecurity by 2030 (SDG Target 2.1). Similarly, despite some progress in the global nutrition targets, the world is not on track to achieve SDG Target 2.2. Among other factors, persistent food price inflation has slowed this momentum.The State of Food Security and Nutrition in the World 2025 highlights how elevated inflation in many countries has undermined purchasing power and, especially among low-income populations, access to healthy diets. The report documents how high food price inflation is associated with increases in food insecurity and child malnutrition. Vulnerable groups, including low-income households, women, and rural communities, can be particularly affected by food price inflation, risking setbacks in the fight against hunger and malnutrition.In response to these challenges and to prevent future price shocks, the report examines policy measures adopted by countries, and outlines what is necessary going forwards. It stresses the importance of coherent implementation of fiscal and monetary policies to stabilize markets, promote open and resilient trade, and protect vulnerable populations. Additionally, it calls for better data systems and sustained investment in resilient agrifood systems to build long-term food security and nutrition. These coordinated actions are vital to reignite progress towards ending hunger and malnutrition by 2030.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;be4b2d92-eb61-4849-a722-f5b41d6bb128&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;234 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eisbn&q;:[{&q;uuid&q;:&q;51a994db-d601-4b9a-85cd-6c0fffdc5040&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-139938-5&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;c48292c2-c7f4-4886-b063-7c5491dde5ae&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2663-807X&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;e6c3fc3b-005b-4333-a477-5d411dbb701b&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-139937-8&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;7f3de20e-0362-40cc-a35d-08dd058d6138&q;,&q;language&