figs&q;},&q;self&q;:{&q;href&q;:&q;https://openknowledge.fao.org/server/api/core/items/8fd0e4be-63c3-4e30-bfd5-950a71f5e56e&q;}},&q;_name&q;:&q;Land and conflict&q;,&q;id&q;:&q;8fd0e4be-63c3-4e30-bfd5-950a71f5e56e&q;,&q;uuid&q;:&q;8fd0e4be-63c3-4e30-bfd5-950a71f5e56e&q;,&q;type&q;:&q;item&q;,&q;metadata&q;:{&q;dc.contributor.author&q;:[{&q;uuid&q;:&q;1debe4b7-e473-4a86-901a-4de68675201f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.accessioned&q;:[{&q;uuid&q;:&q;c1426bcd-39de-4234-8338-6c409721eff2&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-16T13:10:18Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;781d1719-f622-482b-8768-e914f91ba48e&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-16T13:10:18Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;6a6f5e48-62c0-4722-a092-2c5001974bc8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;186257e0-eeda-456f-bcad-a39566c995ef&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-04-16T13:06:51Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;2e484ae0-8fc6-4356-802e-9be0b0f79750&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;This Land Tenure Journal special issue on land and conflict focuses on the increasing incidence of land disputes driven by population growth, climate change, migration and conflict, and their implications for development, food security and peace. It reviews responses to improve land governance, including legal reforms and tenure formalization, while recognizing their limitations, and highlights more inclusive approaches that involve civil society, customary systems and alternative dispute resolution. It also underlines the fragmented nature of current interventions across sectors and the need for stronger coordination and evidence, bringing together experiences and good practices to support more effective management and mitigation of land conflicts.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;ddc45de1-d3ac-4f35-bd4c-0ce0dd82ebf7&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;81&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;bc72bb83-10c5-4d33-983d-0b3c5bd6be13&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2079-7168&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;9b4b54e3-43f9-4119-a543-4cd462798b85&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140137-8&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;829bf49e-5572-4b39-961a-ca89e55b535e&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2079-715X&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;0be11c8d-0694-48bf-88aa-8aeaba32d519&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd9152en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;790ee51c-9f36-4dcd-83fa-65e9e6defeba&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;01e45494-ec15-4d35-9f69-f5ed7e70b2c0&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;ed969ba7-2f2b-4209-bd74-e470af86095c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Land tenure journal&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;b7d87ab4-3369-4459-995a-b2c7e1849a88&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;1–2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;1