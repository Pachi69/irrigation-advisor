&q;:[{&q;uuid&q;:&q;e4bb09f6-838f-4b82-ba27-fd48e3eebda9&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-15T09:55:33Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.available&q;:[{&q;uuid&q;:&q;eb9f1a44-c2c8-4282-be39-af39a05f449b&q;,&q;language&q;:null,&q;value&q;:&q;2026-04-15T09:55:33Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.issued&q;:[{&q;uuid&q;:&q;500e6e07-e3e0-4b8e-9e11-37627982ebb6&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.date.lastModified&q;:[{&q;uuid&q;:&q;29c89b12-b005-49f0-b550-3ba983cdd9c4&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2026-04-15T09:53:00Z&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;c38e1f11-73f2-40bc-a6ca-77c28ef1aa34&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Мировые цены на кукурузу в марте в целом оставались стабильными благодаря обильному предложению, демонстрируя при этом разнонаправленное движение в разных регионах. Мировые экспортные цены на пшеницу выросли на фоне опасений, связанных с погодой, и роста стоимости топлива, осложняющего проведение посевной компании. Мировые цены на рис, напротив, снизились, благодаря достаточным запасам, поступлению на рынок зерна нового урожая, слабому импортному спросу и ослаблению валют некоторых ведущих экспортеров. На внутренних рынках стран, охваченных мониторингом ФАО, основной причиной изменения цен на основные продукты питания в феврале и марте 2026 г. оставались традиционные сезонные факторы. Цены на рис не изменились или снизились, цены на пшеницу подросли, следуя в русле общемировых тенденций. Цены на кормовое зерно демонстрировали большую волатильность из-за отличий локальных условий в различных регионах. Сохраняющиеся высокие цены на основные продукты питания отдельных странах Восточной Африки и Ближнего Востока были обусловлены конфликтами, неблагоприятными погодными условиями и экономическими проблемами. Эскалация ближневосточного конфликта создала огромные риски резкого подорожания продуктов питания на внутренних рынках. В ответ на это многие страны начали реализацию мер, нацеленных на предотвращение резкого подорожания продовольствия из-за увеличения цен на топливо и энергию, нарушения цепочек поставок и обострения экономических проблем.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;0c278ec3-c8a6-4c0d-ad43-3609a03586aa&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;5&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;02cffa8d-97cf-4cd5-b651-d5a3c7ba8e50&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-207X&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;e6fae865-ebe1-46ce-bd29-47859f80e962&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2707-2061&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;1044908c-af0c-4ec3-9b65-1aeea41a1365&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd9328ru&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;46f1d9bd-af5a-461f-b1df-b7d6312cf18f&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Russian&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;c85fb429-6700-4406-a2c7-45d15f147761&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;ФАО ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;b040d646-79b6-4bfe-92bb-e35a4b09a4c8&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FPMA Бюллетень&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;321f3dcf-71ca-46e1-8348-c03a06596620&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;03/2026&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;d9b0e714-4caa-4ce